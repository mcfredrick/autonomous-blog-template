{%- if reddit_subreddits %}

# Reddit RSS — reads official hot.rss feeds. No auth required, but Reddit has
# historically throttled or restructured these feeds. Treat as best-effort.
{%- for sub in reddit_subreddits %}

def reddit_{{ sub | lower | replace('-', '_') | replace('+', '_') }}() -> list[dict]:
    feed = feedparser.parse(
        "https://www.reddit.com/r/{{ sub }}/hot.rss",
        request_headers={"User-Agent": BOT_USER_AGENT},
    )
    results = []
    for entry in feed.entries[:15]:
        results.append({
            "title": entry.get("title", ""),
            "url": entry.get("link", ""),
            "text": entry.get("summary", "")[:400],
        })
    return results
{%- endfor %}
{%- endif %}
{%- if google_news_queries %}

# Google News RSS — free, no API key, covers any topic with news coverage.
{%- for query in google_news_queries %}

def google_news_{{ loop.index }}() -> list[dict]:
    """{{ query }}"""
    import urllib.parse
    q = urllib.parse.quote_plus("{{ query }}")
    feed = feedparser.parse(f"https://news.google.com/rss/search?q={q}&hl=en-US&gl=US&ceid=US:en")
    results = []
    for entry in feed.entries[:10]:
        results.append({
            "title": entry.get("title", ""),
            "url": entry.get("link", ""),
            "text": entry.get("summary", "")[:400],
        })
    return results
{%- endfor %}
{%- endif %}
